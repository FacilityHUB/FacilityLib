local IconAdapter = {}
local _icons = nil
local _loaded = false

local function getIcons()
	if _loaded then return _icons end
	_loaded = true
	local ok, result = pcall(function()
		return loadstring(game:HttpGet(
			'https://raw.githubusercontent.com/FacilityHUB/FacilityLib/refs/heads/main/Addons/Icons'
		))()
	end)
	_icons = ok and result or nil
	if not _icons then warn("IconAdapter | Impossible de charger les icônes") end
	return _icons
end

local function resolve(iconName)
	if type(iconName) == "number" then
		return { image = "rbxassetid://" .. iconName, rectOffset = nil, rectSize = nil }
	end
	if type(iconName) == "string" and (iconName:find("^rbxassetid://") or iconName:find("^rbxasset://")) then
		return { image = iconName, rectOffset = nil, rectSize = nil }
	end
	local icons = getIcons()
	if not icons then return { image = "", rectOffset = nil, rectSize = nil } end
	local normalized = string.match(string.lower(tostring(iconName)), "^%s*(.-)%s*$")
	local entry = icons['48px'] and icons['48px'][normalized]
	if not entry then
		warn("IconAdapter | Icône introuvable : '" .. normalized .. "'")
		return { image = "", rectOffset = nil, rectSize = nil }
	end
	return {
		image = "rbxassetid://" .. entry[1],
		rectOffset = Vector2.new(entry[3][1], entry[3][2]),
		rectSize = Vector2.new(entry[2][1], entry[2][2]),
	}
end

setmetatable(IconAdapter, { __call = function(_, name) return resolve(name) end })
MacLib.Icon = resolve  
function IconAdapter:Apply(imageLabel, iconName)
	local r = resolve(iconName)
	imageLabel.Image = r.image
	if r.rectOffset then imageLabel.ImageRectOffset = r.rectOffset end
	if r.rectSize then imageLabel.ImageRectSize = r.rectSize end
end

function IconAdapter:GetAvailableIcons()
	local icons = getIcons()
	if not icons or not icons['48px'] then return {} end
	local list = {}
	for name in pairs(icons['48px']) do table.insert(list, name) end
	table.sort(list)
	return list
end

