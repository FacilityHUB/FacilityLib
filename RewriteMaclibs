local themesData = getThemes()

MacLib.Themes = {
	Current = themesData.Default or "Dark",
	Names = themesData.Names or { "Dark" },
	List = themesData.List or {},
	Registry = setmetatable({}, { __mode = "k" }),
}

function MacLib:Theme(instance, tags)
	if not instance or not tags then return instance end
	MacLib.Themes.Registry[instance] = tags
	self:UpdateInstance(instance)

	instance.Destroying:Once(function()
		MacLib.Themes.Registry[instance] = nil
	end)

	return instance
end

function MacLib:UpdateInstance(instance)
	local tags = MacLib.Themes.Registry[instance]
	if not tags then return end

	local theme = MacLib.Themes.List[MacLib.Themes.Current]
	if not theme then return end

	for prop, themeKey in pairs(tags) do
		local value = theme[themeKey]
		if value ~= nil then
			pcall(function() instance[prop] = value end)
		end
	end
end

function MacLib:SetTheme(name, animated)
	if not MacLib.Themes.List[name] then
		warn("MacLib | Theme not found: " .. tostring(name))
		return false
	end

	MacLib.Themes.Current = name
	local theme = MacLib.Themes.List[name]
	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	for instance, tags in pairs(MacLib.Themes.Registry) do
		if not instance.Parent and instance.ClassName ~= "ScreenGui" then
			MacLib.Themes.Registry[instance] = nil
		else
			if animated then
				local goals = {}
				for prop, themeKey in pairs(tags) do
					if theme[themeKey] ~= nil then
						goals[prop] = theme[themeKey]
					end
				end
				if next(goals) then
					pcall(function()
						TweenService:Create(instance, tweenInfo, goals):Play()
					end)
				end
			else
				self:UpdateInstance(instance)
			end
		end
	end
	return true
end

function MacLib:GetThemeColor(key)
	local theme = MacLib.Themes.List[MacLib.Themes.Current]
	return theme and theme[key]
end

function MacLib:GetCurrentTheme()
	return MacLib.Themes.Current
end

function MacLib:GetAvailableThemes()
	return MacLib.Themes.Names
end

